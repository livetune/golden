# 黄金价格监控系统配置文件（示例）
# 复制此文件为 config.yaml 并填写实际配置

# API配置
api:
  source: 上金所Au9999
  interval: 40            # 采集间隔(秒)
  timeout: 10             # 请求超时时间(秒)
  retry_times: 3          # 重试次数
  max_history: 500        # 最大历史记录数

# 价格波动算法配置
algorithm:
  threshold: 5            # 波动阈值(元/克)，涨或跌超过此值触发通知
  cooldown: 600           # 通知冷却时间(秒)

# 内存管理配置
memory:
  gc_interval: 60
  max_task_errors: 10

# 邮件配置
email:
  smtp_server: smtp.qq.com
  smtp_port: 465
  use_ssl: true
  sender: your_qq@qq.com          # 替换为你的QQ邮箱
  password: your_auth_code         # 替换为QQ邮箱授权码(非登录密码)
  receivers:
    - target@qq.com                # 替换为收件人邮箱
  timeout: 30
  retry_times: 2

# 日志配置
logging:
  level: INFO
  file: logs/app.log
  max_bytes: 10485760
  backup_count: 5
